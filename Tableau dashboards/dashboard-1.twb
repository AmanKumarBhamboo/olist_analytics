      <aliases enabled='yes' />
      <column caption='Total Orders' datatype='integer' name='[Calculation_3728592995037185]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD([order_id])' />
      </column>
      <column caption='Total Revenue' datatype='real' default-format='C1046%' name='[Calculation_3728592995725314]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([price])' />
      </column>
      <column caption='Average Order Value' datatype='real' default-format='C1046%' name='[Calculation_3728592996282371]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Calculation_3728592995725314] / [Calculation_3728592995037185]' />
      </column>
      <column caption='Unique Customers' datatype='integer' name='[Calculation_3728592997011460]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD([customer_unique_id])' />
      </column>
      <column caption='Average Freight Cost ' datatype='real' default-format='C1046%' name='[Calculation_3728593011732485]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG([freight_value])' />
      </column>
      <column caption='Cohort Month' datatype='datetime' name='[Calculation_3728593024184327]' role='dimension' type='ordinal'>
        <calculation class='tableau' formula='{ FIXED [customer_unique_id] : MIN(DATETRUNC(&apos;month&apos;, DATE([order_purchase_timestamp]))) }' />
      </column>
      <column aggregation='Sum' caption='Months Since First Purchase' datatype='integer' name='[Calculation_3728593024258056]' role='dimension' type='ordinal'>
        <calculation class='tableau' formula='DATEDIFF(&apos;month&apos;, [Calculation_3728593024184327], DATETRUNC(&apos;month&apos;, DATE([order_purchase_timestamp])))' />
      </column>
      <column caption='Orders Per Customer' datatype='integer' name='[Calculation_3728593027829769]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED [customer_unique_id] : COUNTD([order_id]) }' />
      </column>
      <column caption='Actual Delivery Time (Days)' datatype='integer' name='[Calculation_3857716942045184]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='DATEDIFF(&apos;day&apos;, DATE([order_purchase_timestamp]), DATE([order_delivered_customer_date]))' />
      </column>
      <column caption='Estimated Delivery Time (Days)' datatype='integer' name='[Calculation_3857716942123009]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='DATEDIFF(&apos;day&apos;, DATE([order_purchase_timestamp]), DATE([order_estimated_delivery_date]))' />
      </column>
      <column caption='Delivery Performance Status' datatype='string' name='[Calculation_3857716942176258]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [order_delivered_customer_date] &lt;= [order_estimated_delivery_date] THEN &quot;On-Time&quot;&#10;ELSEIF ISNULL([order_delivered_customer_date]) THEN &quot;In-Transit/Canceled&quot;&#10;ELSE &quot;Late Delivery&quot;&#10;END' />
      </column>
      <column caption='Seller Freight Duration' datatype='integer' name='[Calculation_3857716945752075]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='DATEDIFF(&apos;day&apos;, DATE([order_purchase_timestamp]), DATE([order_delivered_carrier_date]))' />
      </column>
